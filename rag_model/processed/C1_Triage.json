        {
            "id": "triage",
            "title": "\u2018Triage\u2019 means \u2018sorting\u2019",
            "intro": "Triage is the process of rapidly assessing all sick children when they first arrive in hospital and sorting them according to their need.",
            "keyPoints": [
                "Triage assessment can be done anywhere such as in out\u2011patients or the ward.",
                "Triage should be carried out, on arrival, to all new patients to the hospital.",
                "Triage can be done by any trained person \u2013 e.g. a health worker, a receptionist, a guard."
            ],
            "categories": [
                {
                    "name": "EMERGENCIES",
                    "label": "E",
                    "color": "red",
                    "description": "Those with life\u2011threatening illness must be seen immediately."
                },
                {
                    "name": "PRIORITIES",
                    "label": "P",
                    "color": "orange",
                    "description": "Those who are less sick must be seen next."
                },
                {
                    "name": "NON\u2011URGENT (QUEUE)",
                    "label": "Q",
                    "color": "green",
                    "description": "Those who are non\u2011urgent can wait their turn in the queue."
                }
            ],
            "categoryTable": [
                {
                    "category": "EMERGENCY [E]",
                    "color": "red",
                    "definition": "patient must be seen at once; may need life\u2011saving treatment"
                },
                {
                    "category": "PRIORITY [P]",
                    "color": "orange",
                    "definition": "patient needs rapid assessment; needs to be seen soon"
                },
                {
                    "category": "NON\u2011URGENT* [Q]",
                    "color": "green",
